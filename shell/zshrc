. "$HOME/.local/bin/env" # bun completions
[ -s "$HOME/.bun/_bun" ] && source "$HOME/.bun/_bun"

# bun
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

# Secrets (fetched from 1Password — never stored on disk)
export OPENAI_API_KEY=$(op read "op://Personal/openai-dotfile/credential" --account my --no-newline)

# Added by Antigravity
export PATH="$HOME/.antigravity/antigravity/bin:$PATH"

# brew
export HOMEBREW_NO_ENV_HINTS=1

# Machine-specific config (not tracked in dotfiles)
[ -f "$HOME/.zshrc.local" ] && source "$HOME/.zshrc.local"
