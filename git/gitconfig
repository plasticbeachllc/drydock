[user]
	name = __NAME__
	email = __EMAIL__
[pull]
	rebase = false
[color]
	ui = auto
[color "status"]
	branch = magenta
[core]
	pager = delta
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	dark = true
	syntax-theme = Catppuccin Mocha
	side-by-side = true
	line-numbers = true
[merge]
	conflictstyle = diff3
[diff]
	colorMoved = default
